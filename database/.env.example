# Database Environment Configuration Template

# MySQL Connection Settings
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=pamphlet_db

# Connection Pool Settings (mysql2/promise)
DB_POOL_SIZE=10
DB_CONNECTION_TIMEOUT=10000
DB_ENABLE_KEEP_ALIVE=true

# For Development
NODE_ENV=development

# For Production (use strong passwords and non-root accounts)
# DB_USER=pamphlet_user
# DB_PASSWORD=very_strong_password_here
# DB_SSL=true

# Optional: Logging
DB_DEBUG=false  # Set to true to see SQL queries in console
